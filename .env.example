# Core database
POSTGRES_USER=iicpc
POSTGRES_PASSWORD=iicpc_secret
POSTGRES_DB=iicpc_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=submissions

# Sandbox manager
SANDBOX_NETWORK=sandbox-net
FLEET_COMMANDER_URL=http://bot-fleet:7070
DEFAULT_NUM_BOTS=100
DEFAULT_DURATION_SECS=60
SANDBOX_MANAGER_HEALTH_PORT=8081

# Telemetry ingester
REDPANDA_BROKERS=redpanda:9092
ORDER_EVENTS_TOPIC=order_events
ORDER_METRICS_TOPIC=order_metrics
GRPC_PORT=8091
HTTP_PORT=8090

# Artifact checker
CONSUMER_GROUP=artifact-checker
ALLOWED_LATENESS_MS=2000
ARTIFACT_CHECKER_GOMAXPROCS=1
HEALTH_PORT=8092
POSTGRES_URL=
REDIS_ADDR=
